# Configuración Backend - HomeForge

# Perfil activo (h2, sqlserver)
SPRING_PROFILES_ACTIVE=sqlserver

# Puerto del servidor
SERVER_PORT=8080

# Orígenes permitidos para CORS (separados por coma)
# IMPORTANTE: Agregar la IP de red para acceso desde otras computadoras
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://172.27.9.148:5174

# Directorio para archivos subidos
UPLOADS_DIRECTORY=uploads

# ============================================
# Configuración de Base de Datos SQL Server
# ============================================
# Para usar SQL Server, inicia con: mvn spring-boot:run -Dspring-boot.run.profiles=sqlserver
# La cadena de conexión usa autenticación integrada de Windows
# DB_URL no es necesario porque está en application-sqlserver.yml
# Si quieres usar autenticación SQL Server, descomenta y configura:
# DB_USERNAME=tu_usuario
# DB_PASSWORD=tu_password
