# Configuración de Base de Datos
# Para H2 (desarrollo sin Docker):
# DB_URL no es necesario (se usa application-h2.yml)

# Para PostgreSQL (con Docker):
# DB_URL=jdbc:postgresql://localhost:5432/casaflow
# DB_USERNAME=casaflow
# DB_PASSWORD=casaflow

# Puerto del servidor
SERVER_PORT=8080

# Orígenes permitidos para CORS (separados por coma)
# Para acceso desde otras computadoras, agregar la IP de red:
# CORS_ALLOWED_ORIGINS=http://localhost:5174,http://192.168.1.100:5174
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Directorio para archivos subidos
UPLOADS_DIRECTORY=uploads

# ============================================
# Configuración de Mercado Pago (SANDBOX)
# ============================================
# Obtener en: https://www.mercadopago.com.mx/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=TEST-ACCESS-TOKEN-AQUI
MERCADOPAGO_PUBLIC_KEY=TEST-PUBLIC-KEY-AQUI

# Precios de planes México (en pesos MXN)
PLAN_STARTER_PRICE=299
PLAN_PRO_PRICE=999
PLAN_BUSINESS_PRICE=3999

# URL del frontend (para redirecciones de pago)
FRONTEND_URL=http://localhost:5174
